{
  "name": "@doon/ui",
  "version": "0.2.2",
  "description": "Shared design tokens, base styles, semantic component classes, React primitives, and Tailwind preset.",
  "license": "MIT",
  "author": "fkhademi",
  "repository": {
    "type": "git",
    "url": "https://github.com/fkhademi/ui.git"
  },
  "type": "module",
  "sideEffects": [
    "src/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/index.css",
    "./tokens.css": "./src/tokens.css",
    "./base.css": "./src/base.css",
    "./components.css": "./src/components.css",
    "./utilities.css": "./src/utilities.css",
    "./tailwind.preset.js": "./tailwind.preset.js"
  },
  "files": [
    "src",
    "dist",
    "tailwind.preset.js",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "react": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "lucide-react": "^0.316.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  }
}
